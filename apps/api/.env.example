# apps/api/.env.example
# Скопируйте в .env и подставьте реальные значения.
# Файл .env НЕ коммитится в git.

# Строка подключения к PostgreSQL
# Формат: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://embrion_app:CHANGE_ME@127.0.0.1:5432/embrion

# Секрет подписи JWT. Минимум 32 случайных символа. Обязательно замените в production.
JWT_SECRET=CHANGE_ME_use_a_long_random_string_here

# Порт HTTP-сервера
PORT=3000
